# Database (Neon Postgres)
DATABASE_URL=
DATABASE_URL_UNPOOLED=

# NextAuth
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=

# OpenAI
OPENAI_API_KEY=

# HabitOS v2 — Phase 1 new env vars
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=coach@habitos.ai
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@habitos.ai
CRON_SECRET=

# HabitOS v2 — M6 Stripe price IDs (one per tier x interval)
# Plan model has no stripePriceId column — these env vars are the source of truth.
# Keys are <SLUG>_<INTERVAL> matching prisma/seed-plan-tiers.ts.
STRIPE_PRICE_STARTER_MONTHLY=price_...
STRIPE_PRICE_STARTER_YEARLY=price_...
STRIPE_PRICE_PRO_MONTHLY=price_...
STRIPE_PRICE_PRO_YEARLY=price_...
STRIPE_PRICE_PREMIUM_MONTHLY=price_...
STRIPE_PRICE_PREMIUM_YEARLY=price_...

# Chrome extension (device-code auth)
EXTENSION_ENABLED=true
# Comma-separated chrome.runtime.id allowlist (no chrome-extension:// prefix).
EXTENSION_IDS=

